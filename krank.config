# KRANK Weekly Update Config
# ─────────────────────────────────────────────
# Spreadsheet URL (for reference)
SHEET_URL = https://docs.google.com/spreadsheets/d/1aXvDc1OuqAs-lQPD4SwmYxZmxTS431Uo/edit?gid=1145078866

# Local Excel file to drop in this folder each week
XLSX_FILE = KRANK_Social_Tracker.xlsx

# Sheet name inside the Excel file
SHEET_NAME = Weekly Tracker

# Column letters in the Excel sheet
COL_NAME       = B    # Celebrity name (must match index.html exactly)
COL_FOLLOWERS  = AB   # Latest Followers (in millions, e.g. 52.1 = 52.1M)
COL_FAN_SCORE  = AD   # Latest Fan Score (0–100)

# Output file
HTML_FILE = index.html
